{
  "name": "practice-vue-i18n",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "dev": "vue-cli-service serve --mode development",
    "build": "vue-cli-service build",
    "lint": "biome lint --files-ignore-unknown=true ./src ./babel.config.js ./vue.config.js",
    "lint:fix": "biome lint --write --files-ignore-unknown=true ./src ./babel.config.js ./vue.config.js",
    "format": "biome format --write --files-ignore-unknown=true ./src ./babel.config.js ./vue.config.js"
  },
  "dependencies": {
    "core-js": "^3.48.0",
    "vue": "^3.5.27",
    "vue-i18n": "^9.14.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@biomejs/biome": "^2.4.6",
    "@vue/cli-plugin-babel": "~5.0.9",
    "@vue/cli-service": "~5.0.9",
    "@vue/compiler-sfc": "^3.5.27",
    "sass": "^1.97.3",
    "sass-loader": "^13.3.3"
  }
}
